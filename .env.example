# ─────────────────────────────────────────────
# JUNK B GONE — Environment Variables
# Copy this file to .env.local and fill in your keys
# NEVER commit .env.local to git
# ─────────────────────────────────────────────

# ── SUPABASE ──────────────────────────────────
# Get these from: https://app.supabase.com → Settings → API
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── HUBSPOT ───────────────────────────────────
# Get this from: HubSpot → Settings → Integrations → Private Apps
# Scopes needed: crm.objects.contacts.write, crm.objects.contacts.read
REACT_APP_HUBSPOT_ACCESS_TOKEN=your-hubspot-private-app-token

# ── BUSINESS INFO ─────────────────────────────
REACT_APP_BUSINESS_PHONE=(786) 555-0199
REACT_APP_BUSINESS_EMAIL=hello@junkbgone.com
